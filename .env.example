# SMTP relay used by app/api/consultation/route.ts to send "Book a consultation"
# form submissions. Defaults below match the client-confirmed SMTP2GO relay
# (no auth — the deploy host's outbound IP must be whitelisted in SMTP2GO, and
# outbound port 25 must be open). Override here only if the relay changes.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=25
SMTP_FROM=noreply@haley365.com
CONSULT_TO_EMAIL=contact@haley365.com
